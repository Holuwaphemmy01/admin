{
  "name": "admin",
  "version": "1.0.0",
  "description": "Node.js Express API with PostgreSQL configuration in TypeScript",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon",
    "dev:tsx": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && tsc -p tsconfig.test.json && node --test --test-isolation=none dist-tests/tests/admin-auth/admin-auth.test.js"
  },
  "keywords": [
    "node",
    "express",
    "postgres"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.13.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.5.2",
    "@types/pg": "^8.11.10",
    "@types/swagger-ui-express": "^4.1.8",
    "nodemon": "^3.1.14",
    "tsx": "^4.19.2",
    "typescript": "^5.9.2"
  }
}
